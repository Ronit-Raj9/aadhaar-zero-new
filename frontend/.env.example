# ====================================================
# Aadhaar-Zero Frontend Environment Variables
# Copy this file to .env.local and fill in the values
# ====================================================

# --- Mode ---
# Set to "false" to use real API routes instead of mock data
NEXT_PUBLIC_DEMO_MODE=true

# --- API Base URL ---
NEXT_PUBLIC_API_BASE_URL=/api

# --- Blockchain: Contract Addresses (Base Sepolia) ---
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_ISSUER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NULLIFIER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CONSENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REVOCATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VERIFIER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AUDIT_TRAIL_ADDRESS=0x0000000000000000000000000000000000000000

# --- RainbowKit / WalletConnect ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# --- Backend Private Key (for server-side blockchain writes) ---
# NEVER expose this in NEXT_PUBLIC_ variables!
BACKEND_PRIVATE_KEY=0x_your_backend_private_key_here

# --- RPC URLs ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# --- AI Services (future integration) ---
# AI_LIVENESS_API_KEY=
# AI_DOCUMENT_API_KEY=
# AI_RISK_API_KEY=
